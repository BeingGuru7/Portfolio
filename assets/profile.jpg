<svg width="500" height="500" xmlns="http://www.w3.org/2000/svg">
  <!-- Background Circle -->
  <circle cx="250" cy="250" r="250" fill="#3182CE"/>
  
  <!-- User Icon -->
  <g transform="translate(250, 250)">
    <!-- Head -->
    <circle cx="0" cy="-30" r="60" fill="white" opacity="0.9"/>
    
    <!-- Body -->
