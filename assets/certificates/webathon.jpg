<svg width="1200" height="900" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="1200" height="900" fill="#f7fafc"/>
  
  <!-- Border -->
  <rect x="50" y="50" width="1100" height="800" fill="none" stroke="#ed8936" stroke-width="8" rx="10"/>
  <rect x="70" y="70" width="1060" height="760" fill="none" stroke="#ed8936" stroke-width="2" rx="5"/>
  
  <!-- Header -->
  <text x="600" y="180" font-family="Georgia, serif" font-size="48" font-weight="bold" fill="#2d3748" text-anchor="middle">
    CERTIFICATE
  </text>
  <text x="600" y="230" font-family="Georgia, serif" font-size="32" fill="#4a5568" text-anchor="middle">
    of Participation
  </text>
  
  <!-- Divider -->
  <line x1="400" y1="270" x2="800" y2="270" stroke="#ed8936" stroke-width="2"/>
  
  <!-- Main text -->
  <text x="600" y="370" font-family="Arial, sans-serif" font-size="42" font-weight="bold" fill="#2d3748" text-anchor="middle">
    Web-A-Thon
  </text>
  <text x="600" y="430" font-family="Arial, sans-serif" font-size="36" font-weight="bold" fill="#2d3748" text-anchor="middle">
    24-hour Hackathon
  </text>
  
  <!-- Issuer -->
  <text x="600" y="560" font-family="Arial, sans-serif" font-size="28" font-weight="bold" fill="#ed8936" text-anchor="middle">
    St. Joseph's College of Engineering
  </text>
  
  <!-- Footer -->
  <text x="600" y="680" font-family="Arial, sans-serif" font-size="20" fill="#718096" text-anchor="middle">
    For outstanding participation and innovation
  </text>
</svg>
