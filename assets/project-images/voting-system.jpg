<svg width="1200" height="600" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="1200" height="600" fill="#1a202c"/>
  
  <!-- Voting boxes -->
  <g opacity="0.3">
    <rect x="300" y="200" width="200" height="150" fill="#3182ce" rx="8"/>
    <rect x="700" y="200" width="200" height="150" fill="#3182ce" rx="8"/>
    <circle cx="350" cy="275" r="15" fill="white"/>
    <circle cx="750" cy="275" r="15" fill="white"/>
  </g>
  
  <!-- Title -->
  <text x="600" y="430" font-family="Arial, sans-serif" font-size="64" font-weight="bold" fill="white" text-anchor="middle">
    Online Voting
  </text>
  
  <!-- Subtitle -->
  <text x="600" y="480" font-family="Arial, sans-serif" font-size="24" fill="#a0aec0" text-anchor="middle">
    Secure Voting System
  </text>
</svg>
