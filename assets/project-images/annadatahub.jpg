<svg width="1200" height="600" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="1200" height="600" fill="#2d3748"/>
  
  <!-- Network/Blockchain connections -->
  <g opacity="0.3">
    <circle cx="400" cy="250" r="40" fill="#48bb78"/>
    <circle cx="600" cy="200" r="40" fill="#48bb78"/>
    <circle cx="800" cy="250" r="40" fill="#48bb78"/>
    <circle cx="600" cy="350" r="40" fill="#48bb78"/>
    
    <line x1="400" y1="250" x2="600" y2="200" stroke="#48bb78" stroke-width="3"/>
    <line x1="600" y1="200" x2="800" y2="250" stroke="#48bb78" stroke-width="3"/>
    <line x1="400" y1="250" x2="600" y2="350" stroke="#48bb78" stroke-width="3"/>
    <line x1="800" y1="250" x2="600" y2="350" stroke="#48bb78" stroke-width="3"/>
  </g>
  
  <!-- Title -->
  <text x="600" y="460" font-family="Arial, sans-serif" font-size="64" font-weight="bold" fill="white" text-anchor="middle">
    AnnadataHub
  </text>
  
  <!-- Subtitle -->
  <text x="600" y="510" font-family="Arial, sans-serif" font-size="24" fill="#a0aec0" text-anchor="middle">
    AI & Blockchain Platform
  </text>
</svg>
